{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "noEmit": false,
    "paths": {
      "@codeer/contracts": ["../contracts/dist/index.d.ts"],
      "@codeer/security": ["../security/dist/index.d.ts"]
    }
  },
  "exclude": ["src/**/*.spec.ts"]
}
