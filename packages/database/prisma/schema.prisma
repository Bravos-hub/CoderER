generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Repository {
  id                 String             @id @default(uuid())
  provider           String
  providerRepoId     String
  installationId     String?
  owner              String
  name               String
  fullName           String
  visibility         String
  defaultBranch      String
  cloneUrl           String
  htmlUrl            String
  headSha            String?
  lastIntakeAt       DateTime?
  incidents          Incident[]
  intakes            RepositoryIntake[]
  worktrees          RepositoryWorktree[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([provider, providerRepoId])
  @@unique([provider, fullName])
}

model RepositoryIntake {
  id                 String               @id @default(uuid())
  repositoryId       String?
  requestedUrl       String
  requestedBranch    String?
  selectedBaseBranch String?
  status             String
  progress           Int                  @default(0)
  error              String?
  repository         Repository?          @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  worktree           RepositoryWorktree?
  requestedAt        DateTime             @default(now())
  completedAt        DateTime?
  updatedAt          DateTime             @updatedAt

  @@index([status, requestedAt])
  @@index([repositoryId, requestedAt])
}

model RepositoryWorktree {
  id             String           @id @default(uuid())
  repositoryId   String
  intakeId       String           @unique
  branchName     String
  baseBranch     String
  baseSha        String
  relativePath   String
  status         String
  repository     Repository       @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  intake         RepositoryIntake @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  sessions       RecoverySession[]
  createdAt      DateTime         @default(now())
  removedAt      DateTime?

  @@index([repositoryId, createdAt])
  @@index([status, createdAt])
}

model Incident {
  id           String            @id @default(uuid())
  repositoryId String
  title        String
  description  String
  severity     String
  status       String
  stage        String
  source       String
  repository   Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  sessions     RecoverySession[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([repositoryId, createdAt])
  @@index([status, severity])
}

model RecoverySession {
  id             String              @id @default(uuid())
  incidentId     String
  worktreeId     String?
  sandboxId      String?
  status         String
  confidence     Float?
  incident       Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  worktree       RepositoryWorktree? @relation(fields: [worktreeId], references: [id], onDelete: SetNull)
  evidence       Evidence[]
  verification   VerificationReport?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([incidentId, createdAt])
  @@index([worktreeId])
}

model Evidence {
  id        String          @id @default(uuid())
  sessionId String
  kind      String
  summary   String
  payload   Json
  session   RecoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@index([sessionId, createdAt])
}

model VerificationReport {
  id                      String          @id @default(uuid())
  sessionId               String          @unique
  status                  String
  originalFailureResolved Boolean
  buildPassed             Boolean
  testsPassed             Boolean
  unexpectedChanges       Json
  confidence              Float
  session                 RecoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt               DateTime        @default(now())
}
