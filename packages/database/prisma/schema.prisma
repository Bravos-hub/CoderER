generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RepositoryProvider {
  GITHUB
}

enum RepositoryVisibility {
  PUBLIC
  PRIVATE
  INTERNAL
}

enum RepositoryIntakeStatus {
  QUEUED
  AUTHENTICATING
  READING_METADATA
  CLONING
  INSPECTING
  CREATING_WORKTREE
  READY
  FAILED
}

enum WorktreeStatus {
  ACTIVE
  REMOVED
  FAILED
}

enum IncidentSeverity {
  SEV1 @map("SEV-1")
  SEV2 @map("SEV-2")
  SEV3 @map("SEV-3")
  SEV4 @map("SEV-4")
}

enum IncidentStatus {
  ADMITTED
  TRIAGING
  INVESTIGATING
  AWAITING_APPROVAL
  RECOVERING
  VERIFYING
  VERIFIED
  FAILED
  CANCELLED
}

enum RecoveryStage {
  ADMIT
  TRIAGE
  DIAGNOSE
  RECOVER
  VERIFY
}

enum IncidentSource {
  MANUAL
  GITHUB_ACTIONS
  WEBHOOK
  API
  MONITORING
}

enum ActorType {
  USER
  SERVICE
  AGENT
  SYSTEM
}

enum IncidentEventType {
  INCIDENT_ADMITTED
  TRIAGE_REQUESTED
  TRIAGE_STARTED
  EVIDENCE_RECORDED
  SEVERITY_ASSESSED
  HEALTH_SNAPSHOT_RECORDED
  TRIAGE_COMPLETED
  STATUS_CHANGED
  RECOVERY_APPROVAL_REQUESTED
  RECOVERY_APPROVED
  INCIDENT_FAILED
  INCIDENT_CANCELLED
  REPRODUCTION_REQUESTED
  SANDBOX_POLICY_APPROVED
  SANDBOX_POLICY_BLOCKED
  SANDBOX_PREPARING
  REPRODUCTION_STARTED
  FAILURE_REPRODUCED
  FAILURE_NOT_REPRODUCED
  REPRODUCTION_TIMED_OUT
  REPRODUCTION_CANCELLED
  SANDBOX_CLEANUP_COMPLETED
  SANDBOX_CLEANUP_FAILED
}

enum EvidenceKind {
  ERROR
  LOG
  COMMAND_OUTPUT
  CI_RUN
  REPOSITORY_METADATA
  CONFIGURATION
  TEST_RESULT
  BUILD_RESULT
  USER_OBSERVATION
  HEALTH_SIGNAL
  SANDBOX_POLICY
  SANDBOX_LOG
  SANDBOX_ARTIFACT
  FAILURE_REPRODUCTION
  SANDBOX_CLEANUP
}

enum EvidenceSource {
  USER
  GITHUB
  SANDBOX
  CI
  AGENT
  SYSTEM
}

enum EvidenceSensitivity {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum HealthStatus {
  HEALTHY
  AT_RISK
  DEGRADED
  CRITICAL
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
  DEAD_LETTER
}

enum AuditOutcome {
  SUCCESS
  DENIED
  FAILURE
}

enum SandboxExecutionStatus {
  REQUESTED
  POLICY_CHECK
  PREPARING
  INSTALLING
  REPRODUCING
  COLLECTING
  CLEANING
  COMPLETED
  POLICY_BLOCKED
  CANCELLED
  TIMED_OUT
  INFRASTRUCTURE_FAILED
  CLEANUP_FAILED
}

enum SandboxResult {
  REPRODUCED
  NOT_REPRODUCED
  INCONCLUSIVE
  POLICY_BLOCKED
  INFRASTRUCTURE_FAILED
}

enum SandboxNetworkMode {
  NONE
  RESTRICTED_INSTALL
}

enum SandboxCommandPhase {
  PREPARE
  INSTALL
  REPRODUCE
  COLLECT
}

enum SandboxCommandStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  TIMED_OUT
  CANCELLED
  POLICY_BLOCKED
}

enum SandboxArtifactRetention {
  EPHEMERAL
  INCIDENT
  LEGAL_HOLD
}

model Organization {
  id             String                     @id @default(uuid())
  slug           String                     @unique
  name           String
  repositories   Repository[]
  intakes        RepositoryIntake[]
  incidents      Incident[]
  evidence       Evidence[]
  healthSnapshots RepositoryHealthSnapshot[]
  auditLogs      AuditLog[]
  outboxMessages OutboxMessage[]
  idempotency    IdempotencyRecord[]
  sandboxExecutions SandboxExecution[]
  reproductions  FailureReproduction[]
  sandboxArtifacts SandboxArtifact[]
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
}

model Repository {
  id                 String                     @id @default(uuid())
  organizationId     String
  provider           RepositoryProvider
  providerRepoId     String
  installationId     String?
  owner              String
  name               String
  fullName           String
  visibility         RepositoryVisibility
  defaultBranch      String
  cloneUrl           String
  htmlUrl            String
  headSha            String?
  lastIntakeAt       DateTime?
  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incidents          Incident[]
  intakes            RepositoryIntake[]
  worktrees          RepositoryWorktree[]
  healthSnapshots    RepositoryHealthSnapshot[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@unique([organizationId, provider, providerRepoId])
  @@unique([organizationId, provider, fullName])
  @@index([organizationId, updatedAt])
}

model RepositoryIntake {
  id                 String                 @id @default(uuid())
  organizationId     String
  repositoryId       String?
  requestedBy        String
  requestedUrl       String
  requestedBranch    String?
  selectedBaseBranch String?
  status             RepositoryIntakeStatus
  progress           Int                    @default(0)
  errorCode          String?
  error              String?
  requestId          String
  organization       Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repository         Repository?            @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  worktree           RepositoryWorktree?
  requestedAt        DateTime               @default(now())
  completedAt        DateTime?
  updatedAt          DateTime               @updatedAt

  @@index([organizationId, status, requestedAt])
  @@index([repositoryId, requestedAt])
}

model RepositoryWorktree {
  id             String            @id @default(uuid())
  repositoryId   String
  intakeId       String            @unique
  branchName     String
  baseBranch     String
  baseSha        String
  relativePath   String
  status         WorktreeStatus
  repository     Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  intake         RepositoryIntake  @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  sessions       RecoverySession[]
  sandboxExecutions SandboxExecution[]
  createdAt      DateTime          @default(now())
  removedAt      DateTime?

  @@index([repositoryId, createdAt])
  @@index([status, createdAt])
}

model Incident {
  id                  String                    @id @default(uuid())
  organizationId      String
  repositoryId        String
  shortCode           String                    @unique
  title               String
  description         String
  severity            IncidentSeverity
  severityScore       Int
  severityReason      String
  status              IncidentStatus
  stage               RecoveryStage
  source              IncidentSource
  externalReference   String?
  labels              String[]                  @default([])
  version             Int                       @default(1)
  impact              Json?
  signals             Json?
  organization        Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repository          Repository                @relation(fields: [repositoryId], references: [id], onDelete: Restrict)
  sessions            RecoverySession[]
  events              IncidentEvent[]
  evidence            Evidence[]
  severityAssessments SeverityAssessment[]
  healthSnapshots     RepositoryHealthSnapshot[]
  auditLogs           AuditLog[]
  sandboxExecutions   SandboxExecution[]
  reproductions       FailureReproduction[]
  sandboxArtifacts    SandboxArtifact[]
  reportedAt          DateTime
  acknowledgedAt      DateTime?
  resolvedAt          DateTime?
  lastActivityAt      DateTime
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([organizationId, status, severity, lastActivityAt(sort: Desc)])
  @@index([organizationId, repositoryId, createdAt(sort: Desc)])
  @@index([organizationId, externalReference])
}

model IncidentEvent {
  id            String            @id @default(uuid())
  incidentId    String
  sequence      Int
  type          IncidentEventType
  payload       Json
  actorType     ActorType
  actorId       String?
  requestId     String?
  correlationId String?
  causationId   String?
  previousHash  String?
  eventHash     String            @unique
  occurredAt    DateTime
  incident      Incident          @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())

  @@unique([incidentId, sequence])
  @@index([incidentId, occurredAt])
  @@index([correlationId])
}

model SeverityAssessment {
  id                 String           @id @default(uuid())
  incidentId         String
  score              Int
  severity           IncidentSeverity
  calculatedSeverity IncidentSeverity
  overrideApplied    Boolean          @default(false)
  rationale          String
  factors            Json
  policyVersion      String
  createdByType      ActorType
  createdById        String?
  incident           Incident         @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@index([incidentId, createdAt(sort: Desc)])
  @@index([severity, createdAt(sort: Desc)])
}

model Evidence {
  id              String              @id @default(uuid())
  organizationId  String
  incidentId      String
  sessionId       String?
  kind            EvidenceKind
  source          EvidenceSource
  sensitivity     EvidenceSensitivity
  title           String
  summary         String
  payload         Json
  contentType     String              @default("application/json")
  byteSize        Int
  digest          String
  redacted        Boolean             @default(false)
  redactionCount  Int                 @default(0)
  origin          String?
  collectionMethod String?
  observedAt      DateTime
  expiresAt       DateTime?
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident        Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  session         RecoverySession?    @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now())

  @@unique([incidentId, digest, kind])
  @@index([organizationId, incidentId, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model RepositoryHealthSnapshot {
  id                 String         @id @default(uuid())
  organizationId     String
  repositoryId       String
  incidentId         String?
  overallScore       Int
  status             HealthStatus
  dimensions         Json
  evidenceCount      Int
  calculationVersion String
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repository         Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  incident           Incident?      @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())

  @@index([organizationId, repositoryId, createdAt(sort: Desc)])
  @@index([incidentId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model RecoverySession {
  id             String              @id @default(uuid())
  incidentId     String
  worktreeId     String?
  sandboxId      String?
  status         String
  confidence     Float?
  incident       Incident            @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  worktree       RepositoryWorktree? @relation(fields: [worktreeId], references: [id], onDelete: SetNull)
  evidence       Evidence[]
  verification   VerificationReport?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([incidentId, createdAt])
  @@index([worktreeId])
}

model VerificationReport {
  id                      String          @id @default(uuid())
  sessionId               String          @unique
  status                  String
  originalFailureResolved Boolean
  buildPassed             Boolean
  testsPassed             Boolean
  unexpectedChanges       Json
  confidence              Float
  session                 RecoverySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt               DateTime        @default(now())
}

model OutboxMessage {
  id             String         @id @default(uuid())
  organizationId String
  topic          String
  partitionKey   String
  deduplicationKey String        @unique
  payload        Json
  status         OutboxStatus   @default(PENDING)
  attempts       Int            @default(0)
  availableAt    DateTime       @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  publishedAt    DateTime?
  lastErrorCode  String?
  lastError      String?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, availableAt, createdAt])
  @@index([organizationId, topic, createdAt])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  incidentId     String?
  action         String
  resourceType   String
  resourceId     String
  actorType      ActorType
  actorId        String?
  outcome        AuditOutcome
  requestId      String?
  correlationId  String?
  reason         String?
  metadata       Json
  previousHash   String?
  auditHash      String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident       Incident?    @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId, createdAt(sort: Desc)])
  @@index([incidentId, createdAt(sort: Desc)])
}

model IdempotencyRecord {
  id             String       @id @default(uuid())
  organizationId String
  scope          String
  key            String
  requestHash    String
  response       Json
  statusCode     Int
  resourceId     String?
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, scope, key])
  @@index([expiresAt])
}


model SandboxPolicySnapshot {
  id                 String                 @id @default(uuid())
  executionId        String                 @unique
  policyVersion      String
  decisionId         String                 @unique
  allowed            Boolean
  reasons            Json
  image              String
  imageDigestRequired Boolean
  normalizedCommands Json
  resourceLimits     Json
  networkPolicy      Json
  overrideRequired   Boolean                @default(false)
  overrideReason     String?
  approvedBy         String?
  evaluatedAt        DateTime
  execution          SandboxExecution       @relation(fields: [executionId], references: [id], onDelete: Cascade)
  createdAt          DateTime               @default(now())
}

model SandboxExecution {
  id                      String                  @id @default(uuid())
  organizationId          String
  incidentId              String
  worktreeId              String
  status                  SandboxExecutionStatus  @default(REQUESTED)
  result                  SandboxResult?
  image                   String
  environmentFingerprint  String?
  leaseOwner              String?
  leaseExpiresAt          DateTime?
  heartbeatAt             DateTime?
  cancellationRequestedAt DateTime?
  startedAt               DateTime?
  completedAt             DateTime?
  errorCode               String?
  errorMessage            String?
  organization            Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident                Incident                @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  worktree                RepositoryWorktree      @relation(fields: [worktreeId], references: [id], onDelete: Restrict)
  reproduction            FailureReproduction?
  policySnapshot          SandboxPolicySnapshot?
  commands                SandboxCommand[]
  logs                    SandboxLogChunk[]
  artifacts               SandboxArtifact[]
  cleanupRecords          SandboxCleanupRecord[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([organizationId, incidentId, createdAt(sort: Desc)])
  @@index([status, leaseExpiresAt])
  @@index([worktreeId, createdAt(sort: Desc)])
}

model FailureReproduction {
  id                       String             @id @default(uuid())
  organizationId           String
  incidentId               String
  executionId              String             @unique
  input                     Json
  status                    SandboxExecutionStatus @default(REQUESTED)
  result                    SandboxResult?
  originalFailureSignature Json
  observedFailureSignature Json?
  signatureComparison      Json?
  confidence               Float?
  environmentFingerprint   String?
  organization             Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident                 Incident           @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  execution                SandboxExecution   @relation(fields: [executionId], references: [id], onDelete: Cascade)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([organizationId, incidentId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@index([result, createdAt])
}

model SandboxCommand {
  id                String               @id
  executionId       String
  sequence          Int
  phase             SandboxCommandPhase
  executable        String
  arguments         String[]
  workingDirectory  String
  environment       Json
  networkMode       SandboxNetworkMode
  timeoutMs         Int
  expectedExitCodes Int[]
  status            SandboxCommandStatus @default(PENDING)
  exitCode          Int?
  signal            String?
  durationMs        Int?
  timedOut          Boolean              @default(false)
  oomKilled         Boolean              @default(false)
  outputDigest      String?
  startedAt         DateTime?
  completedAt       DateTime?
  execution         SandboxExecution     @relation(fields: [executionId], references: [id], onDelete: Cascade)
  logs              SandboxLogChunk[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([executionId, sequence])
  @@index([executionId, status, sequence])
}

model SandboxLogChunk {
  id             String           @id
  executionId    String
  commandId      String?
  sequence       Int
  stream         String
  content        String
  byteSize       Int
  redacted       Boolean          @default(false)
  redactionCount Int              @default(0)
  truncated      Boolean          @default(false)
  previousHash   String?
  chunkHash      String           @unique
  occurredAt     DateTime
  execution      SandboxExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  command        SandboxCommand?  @relation(fields: [commandId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())

  @@unique([executionId, sequence])
  @@index([executionId, occurredAt])
  @@index([commandId, sequence])
}

model SandboxArtifact {
  id               String                   @id
  organizationId   String
  incidentId       String
  executionId      String
  path             String
  mediaType        String
  byteSize         Int
  digest           String
  retention        SandboxArtifactRetention
  storageReference String?
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident         Incident                 @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  execution        SandboxExecution         @relation(fields: [executionId], references: [id], onDelete: Cascade)
  createdAt        DateTime                 @default(now())

  @@unique([executionId, path, digest])
  @@index([organizationId, incidentId, createdAt(sort: Desc)])
  @@index([executionId, createdAt])
}

model SandboxCleanupRecord {
  id             String           @id @default(uuid())
  executionId    String
  containerIds   String[]
  volumeIds      String[]
  networkIds     String[]
  verifiedAbsent Boolean
  attempts       Int
  digest         String
  error          String?
  completedAt    DateTime
  execution      SandboxExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@unique([executionId, digest])
  @@index([executionId, completedAt(sort: Desc)])
}
