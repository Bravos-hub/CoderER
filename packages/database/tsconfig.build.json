{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@codeer/contracts": ["../contracts/dist/index.d.ts"],
      "@codeer/incidents": ["../incidents/dist/index.d.ts"],
      "@codeer/sandbox": ["../sandbox/dist/index.d.ts"],
      "@codeer/recovery": ["../recovery/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts"]
}
