    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "17.2.3",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.16.0",
    "prisma": "7.8.0"
  }
}
