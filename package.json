{
  "name": "codeer",
  "version": "0.1.0",
  "private": true,
  "description": "AI emergency response for broken software.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22 <27",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "dotenv -e .env -- concurrently -n web,api,worker -c auto \"npm run dev -w @codeer/web\" \"npm run dev -w @codeer/api\" \"npm run dev -w @codeer/worker\"",
    "proxy:github-webhook": "node scripts/smee-proxy.mjs",
    "build": "npm run build:packages && npm run build:apps",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run workspace:check && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run security:check",
    "db:generate": "npm run db:generate -w @codeer/database",
    "db:migrate": "npm run db:migrate -w @codeer/database",
    "db:seed": "npm run db:seed -w @codeer/database",
    "demo:reset": "node scripts/demo-reset.mjs",
    "demo:verify": "node scripts/demo-verify.mjs",
    "demo:bootstrap": "node scripts/demo-bootstrap.mjs",
    "demo:start": "npm run dev",
    "demo:tunnel": "cloudflared tunnel --url http://127.0.0.1:3000",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "workspace:check": "node scripts/check-workspace.mjs",
    "clean": "node scripts/clean.mjs",
    "predev": "npm run build:packages",
    "build:packages": "npm run build -w @codeer/contracts && npm run build -w @codeer/config && npm run build -w @codeer/logger && npm run build -w @codeer/incidents && npm run build -w @codeer/security && npm run build -w @codeer/sandbox && npm run build -w @codeer/ai && npm run build -w @codeer/recovery && npm run build -w @codeer/publication && npm run build -w @codeer/database && npm run build -w @codeer/github && npm run build -w @codeer/repository",
    "build:apps": "npm run build -w @codeer/api && npm run build -w @codeer/worker && npm run build -w @codeer/web",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "security:secrets": "node scripts/scan-secrets.mjs",
    "security:sbom": "node scripts/generate-sbom.mjs",
    "security:check": "npm run security:secrets && npm run security:audit",
    "db:deploy": "npm run db:deploy -w @codeer/database",
    "db:validate": "npm run db:validate -w @codeer/database",
    "db:apply:sprint3": "node scripts/apply-sprint3-migration.mjs",
    "test:integration:incident": "node scripts/smoke-incident-engine.mjs",
    "db:provision:runtime": "node scripts/provision-database-runtime-role.mjs",
    "test:integration:sandbox": "node scripts/smoke-sandbox-engine.mjs",
    "sandbox:reconcile": "node scripts/reconcile-sandboxes.mjs",
    "db:migrate:all": "node scripts/apply-codeer-migrations.mjs",
    "db:verify:roles": "node scripts/verify-database-role-boundaries.mjs",
    "test:integration:sandbox:persistence": "node scripts/smoke-sandbox-persistence.mjs",
    "test:integration:sandbox:docker": "node scripts/smoke-sandbox-engine.mjs",
    "test:evaluation:investigation": "tsx scripts/evaluate-investigation-engine.ts",
    "test:integration:investigation": "node scripts/smoke-investigation-persistence.mjs",
    "test:integration:recovery": "node scripts/smoke-recovery-persistence.mjs",
    "test:integration:publication": "node scripts/smoke-publication-closure.mjs",
    "test:integration:demo-reset": "node scripts/smoke-demo-reset.mjs",
    "recovery:reconcile": "node scripts/reconcile-recoveries.mjs",
    "test:evaluation:recovery": "tsx scripts/evaluate-recovery-engine.ts",
    "db:validate:recovery-static": "node scripts/validate-recovery-migration.mjs",
    "db:validate:publication-static": "node scripts/validate-publication-migration.mjs",
    "release:verify-workflows": "node scripts/verify-release-workflows.mjs",
    "test:evaluation:publication": "vitest run packages/publication/src/index.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:live": "PLAYWRIGHT_LIVE=true PLAYWRIGHT_EXTERNAL_SERVER=true playwright test e2e/live-journey.spec.ts",
    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "concurrently": "10.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "smee-client": "^5.0.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
