# CodeER local development configuration. Never commit real credentials.
NODE_ENV=development
LOG_LEVEL=info
WEB_PORT=3000
API_PORT=4100
API_BODY_LIMIT=1mb
API_TRUST_PROXY=false
API_AUTH_MODE=disabled
API_REQUIRE_TENANT_CONTEXT=false
API_REQUIRE_SIGNED_CONTEXT=false
REQUIRE_IDEMPOTENCY_KEYS=false
CODEER_API_KEY=
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120
DEFAULT_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001
DEFAULT_ORGANIZATION_SLUG=local-development
DEFAULT_ORGANIZATION_NAME=Local Development
REQUEST_CONTEXT_SIGNING_SECRET=development-context-signing-secret-change-me
REQUEST_CONTEXT_SIGNING_SECRET_PREVIOUS=
REQUEST_CONTEXT_SIGNATURE_MAX_AGE_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=86400

# Browser-to-API backend-for-frontend. Internal credentials stay server-side.
CODEER_API_URL_INTERNAL=http://localhost:4100/api/v1
CODEER_INTERNAL_API_KEY=
CODEER_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001
CODEER_BFF_ACTOR_ID=codeer-web-bff
CODEER_CONTEXT_SIGNING_SECRET=development-context-signing-secret-change-me
# Separate secret used by the identity edge/OIDC adapter to sign HttpOnly user sessions.
CODEER_USER_SESSION_SECRET=
# Development-only human identity fallback; ignored in production.
CODEER_DEVELOPMENT_USER_ID=local-development-user
CODEER_DEVELOPMENT_USER_ROLES=ORGANIZATION_OWNER
# Demo-only judge access. Set these at runtime for hosted judging; never commit real passwords.
CODEER_JUDGE_ACCESS_ENABLED=false
CODEER_JUDGE_USERNAME=
CODEER_JUDGE_PASSWORD=
CODEER_JUDGE_SESSION_HOURS=8
CODEER_DEMO_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001
CODEER_DEMO_ORGANIZATION_SLUG=competition-demo
CODEER_DEMO_ORGANIZATION_NAME=CodeER Competition Demo
CODEER_DEMO_REPOSITORY_ROOT=/tmp/codeer-demo-repositories
# demo:reset safety tokens. Both are required, and the script additionally
# refuses unknown database hosts/names and any tenant other than the frozen
# competition demo organization.
CODEER_DEMO_RESET_ENABLED=true
CODEER_DEMO_RESET_CONFIRMATION=RESET-COMPETITION-DEMO
CODEER_DEMO_RESET_ALLOWED_HOSTS=localhost,127.0.0.1,postgres
CODEER_DEMO_RESET_ALLOWED_DATABASES=codeer,codeer_demo,codeer_test

# PostgreSQL role separation.
POSTGRES_PASSWORD=development-only
DATABASE_ADMIN_URL=postgresql://codeer:development-only@localhost:5432/codeer
DATABASE_RUNTIME_USER=codeer_app
DATABASE_RUNTIME_PASSWORD=development-app-only
DATABASE_WORKER_USER=codeer_worker
DATABASE_WORKER_PASSWORD=development-worker-only
DATABASE_URL=postgresql://codeer:development-only@localhost:5432/codeer?schema=public

# Redis and asynchronous workers.
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
WORKER_CONCURRENCY=2
REPOSITORY_INTAKE_CONCURRENCY=1
INCIDENT_TRIAGE_CONCURRENCY=4
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_TIMEOUT_MS=30000
OUTBOX_MAX_ATTEMPTS=10

# GitHub App. Prefer short-lived installation tokens and a mounted key file.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_FILE=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
# Optional webhook proxy for local development (e.g. smee.io). GitHub sends
# webhooks to this URL and smee-client forwards them to the local API.
WEBHOOK_PROXY_URL=
GITHUB_API_URL=https://api.github.com

# Repository intake.
REPOSITORY_WORKSPACE_ROOT=/tmp/codeer-workspaces
REPOSITORY_CLONE_DEPTH=1
MAX_REPOSITORY_FILES=100000
MAX_REPOSITORY_BYTES=2147483648
MAX_GITHUB_BRANCHES=500

# Hardened sandbox operator policy.
SANDBOX_DEFAULT_IMAGE=node:24-bookworm-slim
SANDBOX_HELPER_IMAGE=node:24-bookworm-slim
SANDBOX_APPROVED_REGISTRIES=docker.io,ghcr.io
SANDBOX_INSTALL_NETWORK=
SANDBOX_INSTALL_ALLOWED_REGISTRIES=
SANDBOX_INSTALL_ALLOWED_DOMAINS=
SANDBOX_ALLOW_INSTALL_SCRIPTS_OVERRIDE=false
SANDBOX_CPU_CORES=1
SANDBOX_MEMORY_BYTES=1073741824
SANDBOX_PIDS_LIMIT=256
SANDBOX_WORKSPACE_BYTES=2147483648
SANDBOX_TEMP_BYTES=536870912
SANDBOX_COMMAND_TIMEOUT_MS=900000
SANDBOX_EXECUTION_TIMEOUT_MS=2700000
SANDBOX_MAX_COMMANDS=10
SANDBOX_MAX_LOG_BYTES=8388608
SANDBOX_MAX_ARTIFACT_BYTES=67108864
SANDBOX_EXECUTION_CONCURRENCY=1
SANDBOX_EXECUTION_LEASE_MS=60000
SANDBOX_RECONCILE_INTERVAL_MS=60000
SANDBOX_STALE_AFTER_MS=3600000
SANDBOX_DOCKER_HOST=
SANDBOX_DOCKER_TLS_VERIFY=false
SANDBOX_DOCKER_CERT_PATH=
SANDBOX_COMMAND_OUTPUT_LIMIT_BYTES=16777216
SANDBOX_WORKSPACE_VOLUME_DRIVER=
SANDBOX_WORKSPACE_VOLUME_SIZE_OPTION=

# Enterprise AI investigation policy.
# Production values must use organization-approved current model identifiers and pricing.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
AI_ALLOWED_MODELS=gpt-5.6
AI_DEFAULT_MODEL=gpt-5.6
AI_MODEL_PRICING_JSON={}
AI_INVESTIGATION_CONCURRENCY=2
AI_INVESTIGATION_LEASE_MS=90000
AI_INVESTIGATION_RECONCILE_INTERVAL_MS=60000
AI_INVESTIGATION_STALE_AFTER_MS=3600000
AI_MAX_CONTEXT_ITEMS=500
AI_MAX_CONTEXT_BYTES=8388608
AI_MAX_CONTEXT_ITEM_BYTES=262144
AI_MAX_MODEL_INVOCATIONS=20
AI_MAX_TOOL_CALLS=100
AI_MAX_INPUT_TOKENS=200000
AI_MAX_OUTPUT_TOKENS=30000
AI_MAX_COST_USD=25
AI_TIMEOUT_MS=2700000
AI_RETENTION_DAYS=30
AI_STORE_PROVIDER_RESPONSES=false
# Controlled recovery and patch-governance policy.
RECOVERY_ALLOWED_PATHS=apps,packages
RECOVERY_ALLOWED_EXTENSIONS=.ts,.tsx,.js,.jsx,.json,.md,.css,.scss,.html,.yml,.yaml
RECOVERY_MAX_CHANGED_FILES=25
RECOVERY_MAX_CHANGED_LINES=1000
RECOVERY_MAX_PATCH_HUNKS=200
RECOVERY_MAX_PATCH_BYTES=2097152
RECOVERY_ALLOW_NEW_FILES=true
RECOVERY_ALLOW_DELETED_FILES=false
RECOVERY_ALLOW_GENERATED_FILES=false
RECOVERY_ALLOW_DEPENDENCY_CHANGES=false
RECOVERY_ALLOW_LOCKFILE_CHANGES=false
RECOVERY_ALLOW_WORKFLOW_CHANGES=false
RECOVERY_ALLOW_INFRASTRUCTURE_CHANGES=false
RECOVERY_ALLOW_MIGRATION_CHANGES=false
RECOVERY_ALLOW_SECURITY_SENSITIVE_CHANGES=false
RECOVERY_REQUIRED_PUBLICATION_APPROVALS=1
RECOVERY_RETENTION_DAYS=90
RECOVERY_CONCURRENCY=1
RECOVERY_LEASE_MS=90000
RECOVERY_RECONCILE_INTERVAL_MS=60000
RECOVERY_STALE_AFTER_MS=3600000
RECOVERY_WORKTREE_ROOT=/tmp/codeer-recoveries

# Publication execution worker (GitHub Git Data publication of approved recoveries).
PUBLICATION_EXECUTION_CONCURRENCY=1
PUBLICATION_EXECUTION_LEASE_MS=90000
PUBLICATION_RECONCILE_INTERVAL_MS=60000
PUBLICATION_STALE_AFTER_MS=3600000
