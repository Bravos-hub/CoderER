{
  "$schema": "https://json.schemastore.org/design-tokens.json",
  "meta": {
    "name": "CodeER Design Tokens",
    "version": "1.0.0",
    "description": "Canonical visual tokens for CodeER product, website and submission assets."
  },
  "color": {
    "background": {
      "primary": { "$type": "color", "$value": "#071018" },
      "secondary": { "$type": "color", "$value": "#0C1722" }
    },
    "surface": {
      "primary": { "$type": "color", "$value": "#101E2A" },
      "elevated": { "$type": "color", "$value": "#152735" },
      "hover": { "$type": "color", "$value": "#1A3040" }
    },
    "border": {
      "subtle": { "$type": "color", "$value": "#203544" },
      "strong": { "$type": "color", "$value": "#315064" },
      "focus": { "$type": "color", "$value": "#4BA8FF" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "#F5F7FA" },
      "secondary": { "$type": "color", "$value": "#A2B2BF" },
      "muted": { "$type": "color", "$value": "#708593" },
      "inverse": { "$type": "color", "$value": "#071018" }
    },
    "brand": {
      "primary": { "$type": "color", "$value": "#FF4D35" },
      "hover": { "$type": "color", "$value": "#FF654F" },
      "active": { "$type": "color", "$value": "#D93624" }
    },
    "status": {
      "critical": { "$type": "color", "$value": "#FF4D35" },
      "warning": { "$type": "color", "$value": "#FFB547" },
      "investigating": { "$type": "color", "$value": "#4BA8FF" },
      "recovering": { "$type": "color", "$value": "#9A87FF" },
      "stable": { "$type": "color", "$value": "#2BD584" }
    },
    "terminal": {
      "background": { "$type": "color", "$value": "#050A0F" },
      "highlight": { "$type": "color", "$value": "#173144" }
    }
  },
  "font": {
    "family": {
      "display": { "$type": "fontFamily", "$value": "Space Grotesk" },
      "interface": { "$type": "fontFamily", "$value": "Inter" },
      "mono": { "$type": "fontFamily", "$value": "JetBrains Mono" }
    },
    "size": {
      "xs": { "$type": "dimension", "$value": "12px" },
      "sm": { "$type": "dimension", "$value": "14px" },
      "base": { "$type": "dimension", "$value": "16px" },
      "lg": { "$type": "dimension", "$value": "18px" },
      "xl": { "$type": "dimension", "$value": "22px" },
      "2xl": { "$type": "dimension", "$value": "28px" },
      "3xl": { "$type": "dimension", "$value": "36px" },
      "4xl": { "$type": "dimension", "$value": "48px" },
      "display": { "$type": "dimension", "$value": "64px" }
    },
    "weight": {
      "regular": { "$type": "number", "$value": 400 },
      "medium": { "$type": "number", "$value": 500 },
      "semibold": { "$type": "number", "$value": 600 },
      "bold": { "$type": "number", "$value": 700 }
    }
  },
  "spacing": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "16": { "$type": "dimension", "$value": "64px" },
    "20": { "$type": "dimension", "$value": "80px" },
    "24": { "$type": "dimension", "$value": "96px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "10px" },
    "lg": { "$type": "dimension", "$value": "14px" },
    "xl": { "$type": "dimension", "$value": "20px" }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "120ms" },
      "standard": { "$type": "duration", "$value": "180ms" },
      "deliberate": { "$type": "duration", "$value": "280ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
      "exit": { "$type": "cubicBezier", "$value": [0.4, 0, 1, 1] }
    }
  },
  "breakpoint": {
    "sm": { "$type": "dimension", "$value": "640px" },
    "md": { "$type": "dimension", "$value": "768px" },
    "lg": { "$type": "dimension", "$value": "1024px" },
    "xl": { "$type": "dimension", "$value": "1280px" },
    "2xl": { "$type": "dimension", "$value": "1536px" }
  }
}
